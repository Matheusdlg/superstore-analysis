    "# importando as bibliotecas que vou usar no projeto\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# carregando a base da Superstore\n",
    "# usei encoding windows-1252 porque deu erro de leitura com o padrão utf-8\n",
    "df = pd.read_csv('/content/drive/MyDrive/Projeto 03 - Superstore/Sample - Superstore.csv', encoding='windows-1252')\n",
    "\n",
    "df"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# agora separando por categoria pra ver onde está vindo a venda e o lucro\n",
    "print(df.groupby('Category')['Sales'].sum())\n",
    "print('\\n')\n",
    "print(df.groupby('Category')['Profit'].sum())\n",
    "print('\\n')\n",
    "print(df.groupby('Category')['Discount'].mean())\n",
    "\n",
    "# Technology vende mais, mas Furniture chamou atenção pelo lucro mais baixo\n",
    "# vou investigar Furniture mais a fundo"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# filtrando só Furniture pra entender o que está puxando o resultado pra baixo\n",
    "furniture_df = df[ df['Category'] == 'Furniture' ]\n",
    "\n",
    "furniture_df\n",
    "\n",
    "# descendo pra subcategoria\n",
    "print(furniture_df.groupby('Sub-Category')['Sales'].sum())\n",
    "print('\\n')\n",
    "print(furniture_df.groupby('Sub-Category')['Profit'].sum())\n",
    "print('\\n')\n",
    "print(furniture_df.groupby('Sub-Category')['Discount'].mean())\n",
    "\n",
    "# Tables e Bookcases aparecem com Profit negativo, vale olhar com mais calma"
   ]
  },
  {
   "cell_type": "code",
